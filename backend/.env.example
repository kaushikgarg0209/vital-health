# Supabase (from dashboard or `supabase status` for local dev)
SUPABASE_URL=http://127.0.0.1:54321 
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (local Docker — start with `docker compose up -d` from repo root)
REDIS_URL=redis://localhost:6379

# Signed URL TTL for private document downloads (seconds)
SIGNED_URL_TTL_SECONDS=3600

# App
NODE_ENV=development
PORT=3001
# Must match the browser URL (production: https://your-app.vercel.app)
FRONTEND_URL=http://127.0.0.1:3000
# Optional — CORS origin for cookie-based auth (defaults to FRONTEND_URL)
# Optional — defaults to http://localhost:PORT
# BASE_URL=http://localhost:3001
